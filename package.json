{
  "name": "oldcord",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "frontend/*",
    "oldplunger"
  ],
"scripts": {
    "build": "npm run build:selector && npm run build:admin && npm run build:oldplunger && npm run build:server",
    "build:admin": "npx rimraf www_static/assets/admin && npm run build --workspace=frontend/admin",
    "build:oldplunger": "npx rimraf www_static/assets/oldplunger && npm run build --workspace=oldplunger",
    "build:selector": "npx rimraf www_static/assets/selector && npm run build --workspace=frontend/selector",
    "build:server": "npx rimraf dist_server && tsc -p server && node -e \"const fs = require('fs'); const path = './dist_server/helpers/utils/globalutils.js'; if (fs.existsSync(path)) { let text = fs.readFileSync(path, 'utf8'); text = 'const rlObj = { maxPerTimeFrame: 60, timeFrame: 60000 }; global.config = { database: { uri: \\'postgresql://oldcord_db_kl4z_user:SxdNhOEglKyEwROFPI7TKU9kThEZfLB1@dpg-d8vstpgk1i2s73f4jpv0-a/oldcord_db_kl4z\\' }, assetsUrl: \\'https://cdn.oldcordapp.com\\', ratelimit_config: new Proxy({}, { get: () => rlObj }) }; ' + text; fs.writeFileSync(path, text); }\"",
    "dev:admin": "npm run dev --workspace=frontend/admin",
    "dev:oldplunger": "npm run dev --workspace=oldplunger",
    "dev:selector": "npm run dev --workspace=frontend/selector",
    "dev:server": "tsx server/index.ts",
    "biome": "npx @biomejs/biome check .",
    "biome:fix": "npx @biomejs/biome check --write .",
    "lint": "npm run biome",
    "lint:fix": "npm run biome:fix",
    "prepare": "husky",
    "format": "npx @biomejs/biome format --write .",
    "start": "node dist_server/index.js",
    "start:server": "node dist_server/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sapphire/snowflake": "^3.5.5",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^19.1.0-rc.3",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "fluent-ffmpeg": "^2.1.3",
    "jimp": "^1.6.0",
    "libsodium-wrappers": "^0.8.2",
    "mediasoup": "^3.19.17",
    "multer": "^2.1.1",
    "murmurhash-js": "^1.0.0",
    "pg": "^8.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-transition-group": "^4.4.5",
    "rimraf": "^6.1.3",
    "semantic-sdp": "^3.31.1",
    "speakeasy": "^2.0.0",
    "ws": "^8.21.0",
    "youtubei.js": "^16.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.3",
    "@eslint/json": "^1.0.1",
    "@eslint/markdown": "^7.5.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "npm:rolldown-vite@7.3.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "optionalDependencies": {
    "erlpack": "^0.1.4"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.3.1"
  }
